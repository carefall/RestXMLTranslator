<Window
    x:Class="RestXMLTranslator.TextEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Введите текст"
    Width="400"
    Height="300"
    MinWidth="400"
    MinHeight="300"
    Background="{DynamicResource WindowBackgroundBrush}"
    FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
    KeyDown="Window_KeyDown"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="Editor"
            AcceptsReturn="True"
            AcceptsTab="True"
            HorizontalScrollBarVisibility="Auto"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />
        <StackPanel
            Grid.Row="1"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="Ok"
                Width="80"
                Margin="5"
                Click="Ok_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                x:Name="Cancel"
                Width="80"
                Margin="5"
                Content="Отмена"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
