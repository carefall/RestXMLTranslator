<UserControl
    x:Class="RestXMLTranslator.UserControls.ButtonsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button
                MinWidth="160"
                Padding="5,0,5,0"
                Background="#4A90E2"
                BorderBrush="#3B78C2"
                Click="Commit_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_commit]}"
                FontWeight="SemiBold"
                Foreground="White" />
            <Button
                MinWidth="160"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Background="#4A90E2"
                BorderBrush="#3B78C2"
                Click="Download_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_download]}"
                FontWeight="SemiBold"
                Foreground="White" />
            <Button
                MinWidth="160"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="SaveFile_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_save_file]}" />
            <Button
                MinWidth="160"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="SaveAll_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_save_all]}" />
            <Button
                MinWidth="160"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="LoadFile_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_load_file]}" />
            <Button
                MinWidth="160"
                Margin="10,0,10,0"
                Padding="5,0,5,0"
                Click="LoadBuffer_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_load_buffer]}" />
            <Border
                MinWidth="180"
                BorderBrush="Black"
                BorderThickness="1">
                <TextBlock
                    x:Name="Status"
                    MinWidth="180"
                    Margin="5,0,5,0"
                    Padding="5"
                    HorizontalAlignment="Right"
                    FontSize="16"
                    FontWeight="SemiBold"
                    TextAlignment="Center" />
            </Border>
        </StackPanel>
        <!--  FILTERS  -->
        <Grid
            Grid.Row="1"
            Margin="0,10,0,0"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ToggleButton
                Grid.Column="0"
                Checked="FilterChanged"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_approved]}"
                Unchecked="FilterChanged" />

            <ToggleButton
                x:Name="HideUnchanged"
                Grid.Column="1"
                Margin="10,0,10,0"
                Checked="FilterChanged"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_changed]}"
                Unchecked="FilterChanged" />

            <ToggleButton
                x:Name="HideChanged"
                Grid.Column="2"
                Checked="FilterChanged"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_unchanged]}"
                Unchecked="FilterChanged" />

            <Grid
                Grid.Column="3"
                MinWidth="150"
                Margin="10,0,0,0"
                HorizontalAlignment="Stretch">
                <TextBox
                    x:Name="SearchBox"
                    Padding="20,0,5,0"
                    VerticalContentAlignment="Center"
                    TextChanged="SearchBox_TextChanged" />

                <TextBlock
                    Margin="5,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    IsHitTestVisible="False"
                    Text="🔍" />

                <TextBlock
                    x:Name="SearchPlaceholder"
                    Margin="25,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    IsHitTestVisible="False"
                    Text="{Binding Source={StaticResource Locale}, Path=[search_placeholder]}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
