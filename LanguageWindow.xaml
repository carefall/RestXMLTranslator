<Window
    x:Class="RestXMLTranslator.LanguageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Язык / Language"
    Width="185"
    Height="100"
    mc:Ignorable="d">
    <Grid>
        <Button
            x:Name="English"
            Width="75"
            Height="50"
            Margin="0,0,10,0"
            HorizontalAlignment="Right"
            Click="English_Click"
            Content="English" />
        <Button
            x:Name="Russian"
            Width="75"
            Height="50"
            Margin="10,0,0,0"
            HorizontalAlignment="Left"
            Click="Russian_Click"
            Content="Русский" />
    </Grid>
</Window>
