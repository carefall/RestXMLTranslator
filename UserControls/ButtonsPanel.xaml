<UserControl
    x:Class="RestXMLTranslator.UserControls.ButtonsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="Commit"
                Grid.Column="0"
                Height="30"
                MinWidth="175"
                Padding="5,0,5,0"
                Background="#4A90E2"
                BorderBrush="#3B78C2"
                Click="Commit_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_commit]}"
                FontWeight="SemiBold"
                Foreground="White" />
            <Button
                x:Name="Download"
                Grid.Column="1"
                Height="30"
                MinWidth="175"
                Margin="9.5,0,0,0"
                Padding="5,0,5,0"
                Background="#4A90E2"
                BorderBrush="#3B78C2"
                Click="Download_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_download]}"
                FontWeight="SemiBold"
                Foreground="White" />
            <Button
                x:Name="SaveFile"
                Grid.Column="3"
                Height="30"
                MinWidth="175"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="SaveFile_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_save_file]}" />
            <Button
                x:Name="SaveAll"
                Grid.Column="4"
                Height="30"
                MinWidth="175"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="SaveAll_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_save_all]}" />
            <Button
                x:Name="LoadFile"
                Grid.Column="5"
                Height="30"
                MinWidth="175"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="LoadFile_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_load_file]}" />
            <Button
                x:Name="LoadBuffer"
                Grid.Column="6"
                Height="30"
                MinWidth="175"
                Margin="10,0,0,0"
                Padding="5,0,5,0"
                Click="LoadBuffer_Click"
                Content="{Binding Source={StaticResource Locale}, Path=[btn_load_buffer]}" />
            <Button
                Grid.Column="7"
                Width="30"
                Height="30"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="Theme_Click"
                Content="☀" />
        </Grid>
        <Grid
            Grid.Row="1"
            Margin="0,5,0,0"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ToggleButton
                    x:Name="HideApproved"
                    Height="30"
                    Padding="5,0,5,0"
                    Checked="FilterChanged"
                    Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_approved]}"
                    Unchecked="FilterChanged" />
                <ToggleButton
                    x:Name="HideUnchanged"
                    Height="30"
                    Margin="10,0,10,0"
                    Padding="5,0,5,0"
                    Checked="FilterChanged"
                    Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_unchanged]}"
                    Unchecked="FilterChanged" />
                <ToggleButton
                    x:Name="HideChanged"
                    Height="30"
                    Checked="FilterChanged"
                    Content="{Binding Source={StaticResource Locale}, Path=[btn_hide_changed]}"
                    Unchecked="FilterChanged" />
            </StackPanel>
            <Grid
                Grid.Column="1"
                MinWidth="150"
                Margin="10,0,0,0"
                HorizontalAlignment="Stretch">
                <TextBox
                    x:Name="SearchBox"
                    Padding="20,0,5,0"
                    VerticalContentAlignment="Center"
                    TextChanged="SearchBox_TextChanged" />

                <TextBlock
                    Margin="5,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    IsHitTestVisible="False"
                    Text="🔍" />

                <TextBlock
                    x:Name="SearchPlaceholder"
                    Margin="25,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    IsHitTestVisible="False"
                    Text="{Binding Source={StaticResource Locale}, Path=[search_placeholder]}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
