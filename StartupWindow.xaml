<Window
    x:Class="RestXMLTranslator.StartupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="RestXMLTranslator - Инициализация"
    Width="400"
    Height="220"
    FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TextBlock
            x:Name="Text"
            Margin="10,10,10,0"
            VerticalAlignment="Top"
            FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
            FontSize="24"
            Text="Для использования введите никнейм."
            TextAlignment="Center"
            TextWrapping="Wrap" />
        <TextBox
            x:Name="NameBox"
            Height="30"
            Margin="40,10,40,70"
            VerticalAlignment="Bottom"
            VerticalContentAlignment="Center"
            FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
            TextChanged="NameBox_TextChanged" />
        <Grid
            x:Name="Circle"
            Width="32"
            Height="32"
            Margin="0,30,0,0"
            RenderTransformOrigin="0.5,0.5"
            Visibility="Hidden">

            <Grid.RenderTransform>
                <RotateTransform />
            </Grid.RenderTransform>

            <Path
                Stroke="DodgerBlue"
                StrokeEndLineCap="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="4">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure IsClosed="False" StartPoint="16,2">
                            <ArcSegment
                                IsLargeArc="False"
                                Point="30,16"
                                Size="14,14"
                                SweepDirection="Clockwise" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.Angle"
                                From="0"
                                To="360"
                                Duration="0:0:0.8" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
        <Button
            x:Name="ContinueButton"
            Width="100"
            Height="40"
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Click="Button_Click"
            Content="Продолжить"
            FontFamily="Segoe UI, Noto Sans, Arial, Times New Roman"
            IsEnabled="False" />
    </Grid>
</Window>