<UserControl
    x:Class="RestXMLTranslator.UserControls.SyncPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RestXMLTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Panel.ZIndex="100" Background="#66000000">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid
                x:Name="Circle"
                Width="64"
                Height="64"
                Margin="0,30,0,0"
                RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform />
                </Grid.RenderTransform>
                <Path
                    Stroke="DodgerBlue"
                    StrokeEndLineCap="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="8">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure IsClosed="False" StartPoint="32,4">
                                <ArcSegment
                                    IsLargeArc="False"
                                    Point="60,32"
                                    Size="28,28"
                                    SweepDirection="Clockwise" />
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.Angle"
                                    From="0"
                                    To="360"
                                    Duration="0:0:0.8" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
            <TextBlock
                x:Name="SyncTitle"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                FontSize="16"
                Foreground="White"
                Text="{Binding Source={StaticResource Locale}, Path=[sync_title]}" />
        </StackPanel>
    </Grid>
</UserControl>
