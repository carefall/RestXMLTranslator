  <!-- Shadow Cascades Settings -->
  <string id="shw_cascades_title">
    <rus>Настройки каскада теней</rus>
    <eng>Shadow cascade settings</eng>
  </string>
  <string id="shw_cascades_size_1_mcm">
    <rus>Размер ближних каскадов</rus>
    <eng>Near cascade size</eng>
  </string>
  <string id="shw_cascades_size_1_mcm_desc">
    <rus>Меньший размер — лучше качество теней от солнца</rus>
    <eng>Smaller size improves sun shadow quality</eng>
  </string>
  <string id="shw_cascades_size_2_mcm">
    <rus>Размер средних каскадов</rus>
    <eng>Mid cascade size</eng>
  </string>
  <string id="shw_cascades_size_2_mcm_desc">
    <rus>Меньший размер — лучше качество теней от солнца</rus>
    <eng>Smaller size improves sun shadow quality</eng>
  </string>
  <string id="shw_cascades_size_3_mcm">
    <rus>Размер дальних каскадов</rus>
    <eng>Far cascade size</eng>
  </string>
  <string id="shw_cascades_size_3_mcm_desc">
    <rus>Настройка для финального рендеринга теней. Чем выше показатель — тем больше нагрузка на систему</rus>
    <eng>Final shadow rendering setting. Higher values increase system load</eng>
  </string>
  <string id="shw_cascades_grass_shw_quality_mcm">
    <rus>Качество теней от травы</rus>
    <eng>Grass shadow quality</eng>
  </string>
  <string id="shw_cascades_grass_shw_quality_mcm_desc">
    <rus>[Низкие] Тени от травы будут только на ближней дистанции. Стандартный рендеринг Anomaly. [Средние] Тени будут на ближней и средней дистанциях. [Высокие] Тени будут на всех каскадах и при использовании объёмных солнечных лучей. [Ультра] Тени от травы будут при любом типе освещения</rus>
    <eng>[Low] Grass shadows only at close range. [Medium] Close and mid range shadows. [High] Shadows on all cascades with volumetric sun rays. [Ultra] Grass shadows under all lighting conditions</eng>
  </string>
  <string id="ui_mcm_lst_shw_cascades_low">
    <rus>Низкие (стандарт Anomaly)</rus>
    <eng>Low (Anomaly default)</eng>
  </string>
  <string id="ui_mcm_lst_shw_cascades_medium">
    <rus>Средние</rus>
    <eng>Medium</eng>
  </string>
  <string id="ui_mcm_lst_shw_cascades_high">
    <rus>Высокие</rus>
    <eng>High</eng>
  </string>
  <string id="ui_mcm_lst_shw_cascades_ultra">
    <rus>Ультра (большая нагрузка на систему)</rus>
    <eng>Ultra (high system load)</eng>
  </string>
  <string id="shw_cascades_grass_shw_distance_mcm">
    <rus>Дистанция отрисовки теней от травы (тени от солнца)</rus>
    <eng>Grass shadow render distance (sun shadows)</eng>
  </string>
  <string id="shw_cascades_grass_shw_distance_mcm_desc">
    <rus>Этот показатель меняет дистанцию отрисовки теней травы от солнечного света. Имеет процентное отношение с дистанцией прорисовки травы. Меньше значение — меньше нагрузка на систему</rus>
    <eng>Controls grass shadow draw distance from sunlight. Scales with grass render distance. Lower values reduce performance cost</eng>
  </string>
  <string id="shw_cascades_grass_shw_nondir_maxdistance_mcm">
    <rus>Дистанция прорисовки теней от травы</rus>
    <eng>Grass non-directional shadow distance</eng>
  </string>
  <string id="shw_cascades_grass_shw_nondir_maxdistance_mcm_desc">
    <rus>[Только для «Ультра»] Этот показатель влияет на отрисовку теней при непрямом освещении. Меньше значение — меньше нагрузка на систему. При низких значениях тени могут не отрисовываться</rus>
    <eng>[Ultra only] Affects indirect lighting shadows. Lower values reduce performance cost. Too low may disable shadows</eng>
  </string>
